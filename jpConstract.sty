% jpConstract.sty
% 日本語の契約書・条文用のtexスタイルファイル
% 対応エンジン: platex / uplatex

% 後でこのstyファイルを usr/local/texlive/20XX/texmf-dist/tex/platex/ 
% の下にフォルダを作って引っ越し

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{jpConstract}[2026/04/04 Japanese Contract Style]

% ========== 必要なパッケージ ==========
\RequirePackage{geometry}
\RequirePackage{amsmath}
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{tabularx}
\RequirePackage{enumitem}

%% ===== オプション処理 =====
%% \usepackage[a4paper]{keiyaku} などに対応

\newif\if@keiyaku@twoside
\@keiyaku@twosidefalse

\DeclareOption{twoside}{\@keiyaku@twosidetrue}
\DeclareOption{oneside}{\@keiyaku@twosidefalse}
\ProcessOptions\relax

% ========== page layout ==========
\geometry{
  a4paper,
  top=20truemm,bottom=25truemm,left=19truemm,right=19truemm
}

% ========== counter ==========
\newcounter{shou}
\newcounter{jou}          % 条
\newcounter{kou}[jou]     % 項（条がリセットされると項もリセット）
\newcounter{gou}[kou]     % 号（項がリセットされると号もリセット）

%% ===== 題名 =====
\newcommand{\keiyakutitle}[1]{%
  \begin{center}
    {\LARGE\bfseries #1}%
  \end{center}%
  \vspace{1em}%
}

%% ===== 副題（例：「令和○年○月○日締結」） =====
\newcommand{\keiyakudate}[1]{%
  \begin{flushright}
    #1%
  \end{flushright}%
  \vspace{0.5em}%
}

%% ===== 前文 =====
\newcommand{\maebun}[1]{%
  \noindent #1\par
  \vspace{1em}%
}

%% ===== 章（複数の条をまとめる場合） =====
\newcommand{\shou}[1]{%
  \stepcounter{shou}%
  \vspace{1em}%
  \hspace{3zw}\large{\bfseries{ 第\arabic{shou}章\quad #1}}%
  \vspace{0.5em}%
  \par
}

% ========== 条 ==========
%% 使い方
%% 条番号を踏襲: \jou{条の題名}
%% 条番号を指定: \jou[num]{条の題名}
\newcommand{\jou}[2][NOOPT]{
  \def\jouopt{#1}
  \def\jounoopt{NOOPT}
  \vspace{0.8em}

  \ifx\jouopt\jounoopt
    % オプションがないなら、番号を踏襲
    \stepcounter{jou}
  \else
    % オプションの番号を指定して更新する
    \setcounter{jou}{#1}
  \fi
  \noindent{\bfseries{第\arabic{jou}条}\quad{（#2）}}\par
}

%% ===== 項 =====
%% 使い方（項番号あり）: \kou{甲は乙に対し...}
%% 使い方（項番号なし）: \kou*{甲は乙に対し...}
\newcommand{\kou}{%
  \stepcounter{kou}%

  \@ifstar
    {\kou@star}%
    {\kou@nostar}%
}

\newcommand{\kou@star}[1]{
  \noindent\hspace{1zw}#1\par
}

\newcommand{\kou@nostar}[1]{
  \noindent
  \hangindent=2zw\hangafter=1
  \hspace{1zw}\arabic{kou}\quad#1\par
}

%% ===== 号 =====
%% 使い方: \gou{システムの設計...}
\newcommand{\gou}[1]{%
  \stepcounter{gou}%
  \noindent\hspace{3zw}（\arabic{gou}）\quad #1\par
}

%% ===== ただし書き =====
% 必要があれば修正する。
\newcommand{\tadashi}[1]{%
  \noindent\hspace{1zw}\normalsize ただし、#1\par
}

%% ===== なお書き =====
% 必要があれば修正する。
\newcommand{\nao}[1]{%
  \noindent\hspace{1zw}\normalsize なお、#1\par
}

%% ===== 備考・注釈 =====
\newcommand{\biko}[1]{%
  \hspace{2zw}\large\textbf{【備考】}\par
  \hangindent=3zw\hangafter=1
  \hspace{3zw}{\normalsize #1}\par
}

%% ===== 後文 =====
\newcommand{\gobun}[1]{%
  \vspace{2em}%
  \noindent #1\par
}

%% ===== 締結日 =====
\newcommand{\teiketsudate}[1]{%
  \vspace{1em}%
  \noindent #1\par
}

%% ===== 署名欄 =====
%% 使い方: \shomei{甲}{発注者}
\newcommand{\shomei}[2]{%
  \vspace{1em}%
  \noindent\begin{tabularx}{\linewidth}{@{}lX@{}}
    \multicolumn{2}{@{}l@{}}{\bfseries #1（#2）} \\[0.8em]
    住\hspace{1zw}所 & \hrulefill \\[1.2em]
    氏\hspace{1zw}名 & \hrulefill \\[1.2em]
    日\hspace{1zw}付 & \hrulefill \\[0.8em]
  \end{tabularx}%
}

%% ===== 別表見出し =====
%% 使い方: \beppyo{1}{委託業務の内容}
\newcommand{\beppyo}[2]{%
  \vspace{2em}%
  \begin{center}
    {\large\bfseries 別表第#1\quad #2}%
  \end{center}%
  \vspace{0.5em}%
}

% 別紙の機能も欲しい。
% 改ページして、左上に（別紙１）みたいに書く。

% ===================================
% OLD VERSION
% ===================================

% 附則の折り返しがまだ変

% ----- 附則 -----
\newenvironment{Fusoku}{
  \begingroup\par
  \noindent
  \large
  \textbf{附則}
  \par
}{\endgroup \par}

\newcounter{fusokuNum}
\newcommand{\fusoku}[1]{%
  \refstepcounter{fusokuNum}% カウンタを進める
  \indent
  \normalsize
  \text{\arabic{fusokuNum}.} % 項番号
  \text{\ignorespaces#1}
  \par\vspace{1em}% 改行して余白を追加
}

\endinput